# =============================================================================
# packages.x86_64 — Package list for Custom SteamOS ISO
# =============================================================================
# Packages are installed into the ISO's airootfs at build time.
# Lines starting with '#' are comments. One package per line.
# =============================================================================

# ---------------------------------------------------------------------------
# Base system
# ---------------------------------------------------------------------------
base
base-devel
linux-firmware
bash
bash-completion
sudo
nano
vim
htop
wget
curl
git
rsync
arch-install-scripts
gptfdisk
parted
e2fsprogs
dosfstools
ntfs-3g
btrfs-progs

# ---------------------------------------------------------------------------
# Kernel — Neptune (Valve's patched kernel used by SteamOS)
# Use linux-neptune if available via a HoloISO/CachyOS repo,
# otherwise fall back to linux + linux-headers for dkms builds.
# ---------------------------------------------------------------------------
linux
linux-headers

# ---------------------------------------------------------------------------
# NVIDIA drivers (DKMS — required for custom/out-of-tree kernels)
# nvidia-dkms builds the kernel module against whatever kernel-headers
# are installed, making it compatible with linux-neptune-headers when
# that kernel is in use.
# ---------------------------------------------------------------------------
nvidia-dkms
nvidia-utils
lib32-nvidia-utils
nvidia-settings
nvtop

# ---------------------------------------------------------------------------
# Xorg / display stack
# ---------------------------------------------------------------------------
xorg-server
xorg-xinit
xorg-xrandr
mesa
lib32-mesa
vulkan-icd-loader
lib32-vulkan-icd-loader

# ---------------------------------------------------------------------------
# Steam & gaming runtime
# ---------------------------------------------------------------------------
steam
steam-native-runtime
gamescope
mangohud
lib32-mangohud
gamemode
lib32-gamemode

# ---------------------------------------------------------------------------
# Desktop environment (minimal KDE Plasma — mirrors SteamOS)
# ---------------------------------------------------------------------------
plasma-desktop
sddm
plasma-wayland-protocols
xdg-desktop-portal-kde
kscreen
powerdevil

# ---------------------------------------------------------------------------
# Audio
# ---------------------------------------------------------------------------
pipewire
pipewire-alsa
pipewire-pulse
pipewire-jack
wireplumber
alsa-utils

# ---------------------------------------------------------------------------
# Network
# ---------------------------------------------------------------------------
networkmanager
network-manager-applet
iwd
openssh

# ---------------------------------------------------------------------------
# Fonts & theming
# ---------------------------------------------------------------------------
ttf-dejavu
ttf-liberation
noto-fonts
noto-fonts-emoji

# ---------------------------------------------------------------------------
# Live ISO utilities
# ---------------------------------------------------------------------------
memtest86+
syslinux
edk2-shell
